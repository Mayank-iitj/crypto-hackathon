# Q-Shield Environment Configuration
# Copy this file to .env and customize for your environment

# Application
APP_NAME=Q-Shield
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://qshield:qshield123@postgres:5432/qshield
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://redis:6379/0

# Security - IMPORTANT: Generate strong secret keys in production
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Keys (paths inside container)
JWT_PRIVATE_KEY_PATH=/app/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt_public.pem
PLATFORM_SIGNING_KEY_PATH=/app/keys/platform_signing.pem
PLATFORM_PUBLIC_KEY_PATH=/app/keys/platform_public.pem

# Scanning Configuration
SCAN_TIMEOUT_SECONDS=30
SCAN_MAX_CONCURRENT=100
SCAN_RETRY_ATTEMPTS=3
SCAN_BATCH_SIZE=50

# Nmap Configuration
NMAP_PATH=/usr/bin/nmap

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/qshield/app.log
AUDIT_LOG_PATH=/var/log/qshield/audit.log

# CORS
CORS_ORIGINS=https://dashboard.qshield.io,http://localhost:3000

# Certificate Validity
CERTIFICATE_VALIDITY_DAYS=365
CERTIFICATE_VERIFICATION_URL=https://verify.qshield.io/cert

# External APIs (Optional)
WHOIS_API_KEY=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# Feature Flags
PQC_DETECTION_ENABLED=true
HYBRID_TLS_DETECTION_ENABLED=true
DOWNGRADE_ATTACK_DETECTION_ENABLED=true

# Compliance
NIST_SP_800_208_ENABLED=true
ISO_27001_ENABLED=true
RBI_CSF_ENABLED=true

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=admin

# Email Configuration (Optional - for notifications)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@qshield.io

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=

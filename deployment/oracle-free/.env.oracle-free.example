# Oracle Always Free deployment environment template
# Copy this file to project root as .env and update values.

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# Required app secret (replace with generated value)
# openssl rand -base64 48
SECRET_KEY=REPLACE_WITH_STRONG_SECRET

# Core service passwords
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
GRAFANA_PASSWORD=REPLACE_WITH_STRONG_GRAFANA_PASSWORD

# Public URL and API URL
# Example:
# PUBLIC_URL=http://YOUR_VM_PUBLIC_IP:3000
# API_URL=http://YOUR_VM_PUBLIC_IP:8000
PUBLIC_URL=http://localhost:3000
API_URL=http://localhost:8000

# CORS and host restrictions
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# OAuth placeholders (set real values only if using OAuth)
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
MICROSOFT_CLIENT_ID=placeholder
MICROSOFT_CLIENT_SECRET=placeholder

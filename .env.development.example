# Q-Shield Environment Variables - Development Example
# Copy to .env.development and customize for your environment

# Environment Mode
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
ALLOWED_HOSTS=["localhost", "127.0.0.1", "localhost:3000", "127.0.0.1:3000"]
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Database Configuration
DATABASE_URL=postgresql+asyncpg://qshield:qshield123@localhost:5432/qshield
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=qshield
DATABASE_USER=qshield
DATABASE_PASSWORD=qshield123
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Cache/Queue Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false

# Security Configuration
SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT Configuration
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=RS256
JWT_EXPIRATION_SECONDS=3600

# OAuth - Google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
GOOGLE_SCOPE=openid email profile

# OAuth - GitHub
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE
GITHUB_REDIRECT_URI=http://localhost:8000/auth/oauth/github/callback
GITHUB_SCOPE=user:email

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID_HERE
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET_HERE
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/oauth/microsoft/callback
MICROSOFT_SCOPE=openid profile email

# Elasticsearch Configuration
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_VERIFY_CERTS=false

# Grafana Configuration
GRAFANA_HOST=localhost
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_PROVISIONING_ENABLED=true

# SMTP Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# Application Settings
APP_NAME=Q-Shield
APP_DESCRIPTION=Quantum-Ready Security Platform
APP_VERSION=1.0.0

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PORT=9000
PROMETHEUS_SCRAPE_INTERVAL=15

# Feature Flags
FEATURE_ASSET_DISCOVERY=true
FEATURE_CBOM_GENERATION=true
FEATURE_QUANTUM_VALIDATION=true
FEATURE_COMPLIANCE_MAPPING=true
FEATURE_CERTIFICATE_ISSUANCE=true

# Logging
LOG_FORMAT=json
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/qshield/app.log

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Backup Configuration (Development - disabled by default)
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7

# Compliance Framework
COMPLIANCE_FRAMEWORK_ENABLED=true
NIST_PQC_MIGRATION_ENABLED=true
ISO_27001_MAPPING_ENABLED=true
RBI_FRAMEWORK_ENABLED=true

# Development-Specific Settings
SKIP_SSL_VERIFICATION=true
MOCK_EXTERNAL_SERVICES=false
ENABLE_SWAGGER_UI=true
ENABLE_REDOC=true

# Timezone
TZ=UTC

# Additional Configuration
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_CONNECTIONS=1000

# Database Migrations (Auto-migrate on startup in development)
AUTO_MIGRATE=true

# Seed Data (Populate test data on startup in development)
SEED_DATABASE=false
